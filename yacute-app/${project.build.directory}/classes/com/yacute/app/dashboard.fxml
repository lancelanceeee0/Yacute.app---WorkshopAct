<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            style="-fx-background-color: #f5f5f5;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.yacute.app.DashboardController">

    <children>

        <HBox alignment="CENTER"
              spacing="30.0"
              AnchorPane.bottomAnchor="20.0"
              AnchorPane.leftAnchor="20.0"
              AnchorPane.rightAnchor="20.0"
              AnchorPane.topAnchor="20.0">

            <!-- LEFT CARD -->
            <VBox alignment="CENTER"
                  spacing="20.0"
                  prefWidth="360.0"
                  style="-fx-background-color: white;
                         -fx-background-radius: 25;
                         -fx-padding: 30;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 18, 0, 0, 5);">

                <children>

                    <ImageView fx:id="imageView"
                               fitHeight="340.0"
                               fitWidth="340.0"
                               preserveRatio="true">

                        <image>
                            <Image url="@image.png"/>
                        </image>
                    </ImageView>

                    <Label text="Yacute Dashboard"
                           style="-fx-font-size: 34px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #e4572e;"/>

                    <Label text="Simple Login Monitoring System"
                           style="-fx-font-size: 16px;
                                  -fx-text-fill: #777777;"/>

                    <Button text="Logout"
                            onAction="#handleLogout"
                            prefWidth="220.0"
                            prefHeight="48.0"
                            style="-fx-background-color: #e85d3f;
                                   -fx-text-fill: white;
                                   -fx-font-size: 16px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 18;
                                   -fx-cursor: hand;"/>

                </children>
            </VBox>

            <!-- RIGHT CARD -->
            <VBox spacing="20.0"
                  prefWidth="420.0"
                  alignment="TOP_CENTER"
                  style="-fx-background-color: white;
                         -fx-background-radius: 25;
                         -fx-padding: 30;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 18, 0, 0, 5);">

                <children>

                    <Label text="Recent Login Logs"
                           style="-fx-font-size: 32px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #333333;"/>

                    <TableView fx:id="logTable"
                               prefHeight="420.0"
                               prefWidth="360.0"
                               style="-fx-background-radius: 18;
                                      -fx-border-radius: 18;">

                        <columns>
                            <TableColumn fx:id="dateTimeColumn"
                                         prefWidth="355.0"
                                         text="Login Date &amp; Time"/>
                        </columns>

                    </TableView>

                </children>
            </VBox>

        </HBox>

    </children>
</AnchorPane>