<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<AnchorPane prefHeight="500.0" prefWidth="850.0"
            style="-fx-background-color: linear-gradient(to bottom right, #fff5f0, #ffe9d6);"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.yacute.app.LoginController">

   <children>

      <HBox alignment="CENTER"
            spacing="50.0"
            AnchorPane.bottomAnchor="0.0"
            AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0"
            AnchorPane.topAnchor="0.0">

         <padding>
            <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
         </padding>

         <children>

            <!-- Left Side -->
            <VBox alignment="CENTER" spacing="18.0"
                  prefWidth="320.0">

               <children>

                  <Label text="WELCOME"
                         style="-fx-font-size: 42px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #d94f30;"/>

                  <Label text="Log in to see a cute thing ✨"
                         style="-fx-font-size: 18px;
                      -fx-text-fill: #666666;"/>

               </children>
            </VBox>
            <!-- Right Side Login Card -->
            <VBox alignment="CENTER"
                  spacing="18.0"
                  prefWidth="320.0"
                  style="-fx-background-color: white;
                             -fx-background-radius: 25;
                             -fx-padding: 35;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 18, 0, 0, 6);">

               <children>

                  <Label text="Welcome Back"
                         style="-fx-font-size: 28px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #333333;"/>

                  <Label text="Login to continue"
                         style="-fx-font-size: 14px;
                                      -fx-text-fill: #888888;"/>

                  <TextField fx:id="usernameField"
                             promptText="Username"
                             prefHeight="42.0"
                             style="-fx-background-radius: 12;
                                          -fx-font-size: 14px;
                                          -fx-padding: 10;"/>

                  <PasswordField fx:id="passwordField"
                                 promptText="Password"
                                 prefHeight="42.0"
                                 style="-fx-background-radius: 12;
                                              -fx-font-size: 14px;
                                              -fx-padding: 10;"/>

                  <Button text="Log In"
                          onAction="#handleLogin"
                          prefWidth="220.0"
                          prefHeight="42.0"
                          defaultButton="true"
                          style="-fx-background-color: #e85d3f;
                                       -fx-text-fill: white;
                                       -fx-font-size: 15px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 15;
                                       -fx-cursor: hand;"/>

                  <Label fx:id="errorLabel"
                         style="-fx-text-fill: #e53935;
                                      -fx-font-size: 13px;"/>

               </children>
            </VBox>

         </children>
      </HBox>

   </children>
</AnchorPane>
